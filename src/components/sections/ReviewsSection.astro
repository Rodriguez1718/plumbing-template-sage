---
import { Quote, Star, CheckCircle, ArrowRight } from "@lucide/astro";
import { getLocationText } from "@/config/site";

interface Review {
	name: string;
	time: string;
	content: string;
	readMoreHref?: string;
}

interface Props {
	badge?: string;
	title: string;
	description?: string;
	reviews: Review[];
	verifiedBy?: string;
}

const {
	badge: raw_badge = "GOOGLE REVIEW",
	title: raw_title,
	description: raw_description,
	reviews: rawReviews,
	verifiedBy = "Verified by Trustindex",
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description
	? getLocationText(raw_description)
	: raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const reviews = rawReviews.map((r) => ({
	...r,
	content: getLocationText(r.content),
}));
---

<section
	class="py-24 md:py-32 bg-white relative overflow-hidden border-b-4 border-primary">
	{/* Technical Background */}
	<div
		class="absolute inset-0 opacity-[0.03] pointer-events-none"
		style="background-image: radial-gradient(var(--brand-primary, #000) 2px, transparent 0); background-size: 30px 30px;">
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="max-w-6xl mx-auto">
			<div class="mb-20" data-animate="fade-up">
				<div class="flex items-center gap-3 mb-6">
					<span
						class="inline-block bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]"
						>{badge}</span
					>
				</div>
				<h2
					class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-[1.1] mb-8">
					{title}
				</h2>
				{
					description && (
						<p
							class="text-lg font-medium leading-relaxed text-primary max-w-2xl"
							set:html={description}
						/>
					)
				}
			</div>

			<div
				class="grid md:grid-cols-2 lg:grid-cols-4 gap-8"
				data-animate-stagger>
				{
					reviews.map((review) => (
						<div class="group relative bg-white border-4 border-primary p-8 shadow-[12px_12px_0px_var(--brand-secondary,rgba(0,0,0,0.1))] hover:shadow-[16px_16px_0px_var(--accent)] transition-all duration-500 flex flex-col h-full rounded-none">
							<div class="absolute top-0 right-8 bg-primary text-white text-[10px] font-black px-4 py-1 uppercase tracking-widest">
								SOURCE_PLATFORM
							</div>

							<div class="flex items-center gap-4 mb-6">
								<div class="w-12 h-12 bg-primary text-white flex items-center justify-center font-black text-xl group-hover:bg-accent group-hover:text-primary transition-colors">
									{review.name
										.split(" ")
										.map((n) => n[0])
										.join("")}
								</div>
								<div class="overflow-hidden">
									<p class="font-black text-primary uppercase tracking-tighter truncate">
										{review.name}
									</p>
									<p class="text-[10px] font-black text-primary/70 uppercase tracking-widest">
										{review.time}
									</p>
								</div>
							</div>

							<div class="flex gap-1 mb-4" aria-label="Rating: 5 out of 5 stars">
								{[...Array(5)].map(() => (
									<Star class="w-3.5 h-3.5 fill-accent text-accent" aria-hidden="true" />
								))}
							</div>

							<div class="relative flex-grow">
								<Quote class="absolute -top-2 -left-2 w-8 h-8 text-accent/10 -z-10" />
								<p
									class="text-sm font-bold uppercase tracking-tight text-primary/80 leading-relaxed mb-6 line-clamp-6"
									set:html={review.content}
								/>
							</div>

							{review.readMoreHref && (
								<a
									href={review.readMoreHref}
									class="mt-auto flex items-center gap-2 text-[10px] font-black text-accent uppercase tracking-widest hover:text-primary transition-colors group/link"
									aria-label={`Read more about ${review.name}'s review`}
								>
									INITIALIZE_READ_MORE
									<ArrowRight class="w-3 h-3 group-hover/link:translate-x-1 transition-transform" />
								</a>
							)}
						</div>
					))
				}
			</div>

			{
				verifiedBy && (
					<div class="mt-16 text-center border-t-4 border-primary/5 pt-12">
						<div class="inline-flex items-center gap-4 px-8 py-4 bg-white border-4 border-primary shadow-[8px_8px_0px_var(--brand-secondary,rgba(0,0,0,0.05))]">
							<CheckCircle class="w-6 h-6 text-accent stroke-[3px]" />
							<div class="text-left">
								<p class="text-[10px] font-black uppercase tracking-widest text-primary/70">
									VERIFICATION_STATUS
								</p>
								<p class="text-sm font-black uppercase tracking-tighter text-primary">
									{verifiedBy.toUpperCase()}
								</p>
							</div>
						</div>
					</div>
				)
			}
		</div>
	</div>
</section>
