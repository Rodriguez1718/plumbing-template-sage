---
import { getLocationText } from "@/config/site"

interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge: raw_badge = "Testimonials", title: raw_title, description: raw_description, testimonials: rawTestimonials } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const testimonials = rawTestimonials.map(t => ({
  ...t,
  content: getLocationText(t.content),
}));
---

<section class="py-20 md:py-32 bg-card relative overflow-hidden" style="border-bottom: 3px solid var(--brand-primary, #45f9ff);">
	<!-- Technical Grid Background -->
	<div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(var(--brand-primary, #45f9ff) 2px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8" data-animate="fade-up">
			<div class="max-w-3xl space-y-4">
				<span class="inline-block bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
					{badge}
				</span>
				<h2 class="text-4xl md:text-6xl font-black text-foreground leading-none tracking-tighter uppercase">
					Client <br/><span class="text-primary">Intelligence</span>
				</h2>
			</div>
      {description && <p class="text-lg text-muted-foreground font-medium max-w-xl border-l-4 border-accent pl-8" set:html={description} />}
    </div>

    <div class="testimonials-carousel relative overflow-hidden" data-animate="fade-up">
			{/* Fade Gradients for sides */}
			<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-card to-transparent z-10 pointer-events-none"></div>
			<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-card to-transparent z-10 pointer-events-none"></div>

      <div class="testimonials-marquee flex py-10" style="will-change: transform;">
        {/* Render cards twice for seamless loop */}
        {[...testimonials, ...testimonials].map((testimonial, i) => (
          <div class="flex-shrink-0 w-[320px] sm:w-[400px] px-4">
            <div class="group relative h-full">
							{/* Brutalist Shadow Offset */}
							<div class="absolute inset-0 bg-accent translate-x-2 translate-y-2 transition-transform group-hover:translate-x-4 group-hover:translate-y-4"></div>
							
							<div class="relative bg-white border-4 border-primary p-8 flex flex-col h-full">
								<div class="flex items-center gap-4 mb-6">
									<div class="w-14 h-14 bg-primary text-white flex items-center justify-center shrink-0">
										<span class="text-xl font-black uppercase">{testimonial.initials}</span>
									</div>
									<div>
										<h4 class="text-sm font-black uppercase tracking-tight text-primary leading-none">{testimonial.name}</h4>
										<p class="text-[10px] font-bold text-foreground/80 uppercase tracking-widest mt-1">{testimonial.date}</p>
									</div>
								</div>

								<div class="flex gap-1 mb-6">
									{Array.from({ length: 5 }).map((_, i) => (
										<div class={`w-4 h-4 ${i < testimonial.rating ? 'bg-accent' : 'bg-primary/10'}`}></div>
									))}
								</div>

								<div class="relative flex-grow">
									<span class="absolute -top-4 -left-4 text-4xl font-black text-primary/10 select-none">"</span>
									<p class="text-sm font-bold text-foreground/80 leading-relaxed uppercase tracking-tight italic" set:html={testimonial.content} />
								</div>

								<div class="mt-8 flex items-center justify-between">
									<div class="flex gap-2">
										<div class="w-8 h-1 bg-primary"></div>
										<div class="w-2 h-1 bg-accent"></div>
									</div>
									<span class="text-[10px] font-black uppercase text-primary/70 tracking-tighter">Verified Client</span>
								</div>
							</div>
						</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-marquee {
    animation: marquee 60s linear infinite;
    width: max-content;
  }
  
  .testimonials-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .testimonials-marquee {
      animation-duration: 40s;
    }
  }
</style>

<script>
  function initTestimonialsMarquee() {
    document.querySelectorAll<HTMLElement>('.testimonials-carousel').forEach((carousel) => {
      const marquee = carousel.querySelector<HTMLElement>('.testimonials-marquee');
      if (!marquee) return;

      // Prevent re-init
      if (marquee.dataset.init === 'true') return;
      marquee.dataset.init = 'true';

      let offset = 0;
      let speed = 0.5; // px per frame
      let paused = false;
      let dragging = false;
      let dragStartX = 0;
      let dragOffsetStart = 0;
      let momentum = 0;
      let rafId: number;

      // Half-width = width of the original set of cards (before duplication)
      function getHalfWidth(): number {
        return marquee!.scrollWidth / 2;
      }

      function wrapOffset() {
        const half = getHalfWidth();
        if (half > 0) {
          offset = ((offset % half) + half) % half;
        }
      }

      function animate() {
        if (dragging) {
          // During drag, offset is set directly by pointer events
        } else if (momentum !== 0) {
          offset += momentum;
          momentum *= 0.95;
          if (Math.abs(momentum) < 0.1) momentum = 0;
        } else if (!paused) {
          offset += speed;
        }
        wrapOffset();
        marquee!.style.transform = `translateX(-${offset}px)`;
        rafId = requestAnimationFrame(animate);
      }

      // Auto-scroll pause on hover (only when not dragging)
      carousel.addEventListener('mouseenter', () => { if (!dragging) paused = true; });
      carousel.addEventListener('mouseleave', () => { paused = false; dragging = false; });

      // --- Mouse drag ---
      carousel.addEventListener('mousedown', (e: MouseEvent) => {
        dragging = true;
        paused = true;
        momentum = 0;
        dragStartX = e.clientX;
        dragOffsetStart = offset;
        e.preventDefault();
      });

      window.addEventListener('mousemove', (e: MouseEvent) => {
        if (!dragging) return;
        const delta = dragStartX - e.clientX;
        offset = dragOffsetStart + delta;
      });

      window.addEventListener('mouseup', () => {
        if (!dragging) return;
        dragging = false;
        // Calculate momentum from final drag delta
        momentum = offset - dragOffsetStart > 0 ? 2 : offset - dragOffsetStart < 0 ? -2 : 0;
      });

      // --- Touch drag ---
      let touchStartX = 0;
      let lastTouchX = 0;

      carousel.addEventListener('touchstart', (e: TouchEvent) => {
        dragging = true;
        paused = true;
        momentum = 0;
        touchStartX = e.touches[0].clientX;
        lastTouchX = touchStartX;
        dragOffsetStart = offset;
      }, { passive: true });

      carousel.addEventListener('touchmove', (e: TouchEvent) => {
        if (!dragging) return;
        const currentX = e.touches[0].clientX;
        const delta = touchStartX - currentX;
        offset = dragOffsetStart + delta;
        lastTouchX = currentX;
      }, { passive: true });

      carousel.addEventListener('touchend', () => {
        if (!dragging) return;
        dragging = false;
        const totalDelta = offset - dragOffsetStart;
        momentum = totalDelta > 0 ? 2 : totalDelta < 0 ? -2 : 0;
        // Resume auto-scroll after a short delay
        setTimeout(() => { paused = false; }, 2000);
      }, { passive: true });

      // Respect reduced motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        paused = true;
      }

      rafId = requestAnimationFrame(animate);

      // Cleanup on page transition
      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(rafId);
      }, { once: true });
    });
  }

  initTestimonialsMarquee();
  document.addEventListener('astro:page-load', initTestimonialsMarquee);
</script>
