---
interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge = "Testimonials", title, description, testimonials } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <span class="text-sm font-semibold text-primary uppercase tracking-wide">{badge}</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-4">{title}</h2>
      {description && <p class="text-muted-foreground max-w-3xl mx-auto">{description}</p>}
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map((testimonial) => (
        <div class="bg-card border rounded-lg p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full bg-muted flex items-center justify-center">
              <span class="text-lg font-semibold">{testimonial.initials}</span>
            </div>
            <div>
              <h4 class="font-semibold">{testimonial.name}</h4>
              <p class="text-xs text-muted-foreground">{testimonial.date}</p>
            </div>
          </div>
          <div class="flex text-yellow-500 mb-3">
            {Array.from({ length: testimonial.rating }).map(() => "★").join("")}
          </div>
          <p class="text-sm text-muted-foreground">{testimonial.content}</p>
        </div>
      ))}
    </div>
  </div>
</section>
