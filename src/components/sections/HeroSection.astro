---
import { getLocationText } from "@/config/site"

interface HeroSlide {
  title: string;
  subtitle?: string;
  image: string;
  promoTitle?: string;
  promoText?: string;
  promoImage?: string;
  buttonText?: string;
}

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  slides?: HeroSlide[];
  variant?: "default" | "subpage" | "category";
}

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  slides?: HeroSlide[];
  variant?: "default" | "subpage" | "category";
  trustIndicators?: string[];
}

const {
  badge,
  title: rawTitle,
  subtitle: rawSubtitle,
  buttonText: rawButtonText = "Call Now",
  buttonHref: rawButtonHref = "tel:{phoneRaw}",
  image,
  slides: rawSlides = [],
  variant = "default",
  trustIndicators: rawTrustIndicators,
} = Astro.props;

// Process all text placeholders
const title = rawTitle ? getLocationText(rawTitle) : "";
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const badge_processed = badge ? getLocationText(badge) : undefined;
const buttonText = getLocationText(rawButtonText);
const buttonHref = getLocationText(rawButtonHref);
const trustIndicators = rawTrustIndicators ? rawTrustIndicators.map(t => getLocationText(t)) : undefined;

// Process slide text
const slides = rawSlides.map(slide => ({
  ...slide,
  title: getLocationText(slide.title),
  subtitle: slide.subtitle ? getLocationText(slide.subtitle) : undefined,
  promoTitle: slide.promoTitle ? getLocationText(slide.promoTitle) : undefined,
  promoText: slide.promoText ? getLocationText(slide.promoText) : undefined,
  promoImage: slide.promoImage || undefined,
  buttonText: slide.buttonText ? getLocationText(slide.buttonText) : undefined,
}));

const hasSlideshow = slides.length > 1;
---

{variant === "subpage" ? (
  <section class="subpage-hero relative bg-primary overflow-hidden">
    {/* Sharp geometric background pattern */}
    <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(var(--brand-highlight, #45f9ff) 2px, transparent 0); background-size: 30px 30px;"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="grid md:grid-cols-12 min-h-[480px] md:min-h-[560px] items-center">
        <div class="md:col-span-7 relative py-12 sm:py-20 md:py-24">
          {badge_processed && (
            <div class="mb-8">
              <span class="inline-block bg-accent text-primary text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
                {badge_processed}
              </span>
            </div>
          )}
          
          <div class="space-y-6">
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl font-black text-white leading-[0.95] tracking-tighter uppercase">
              {title}
            </h1>
            
            {subtitle && (
              <p class="text-lg sm:text-xl md:text-2xl text-white/70 max-w-xl leading-relaxed font-medium border-l-4 border-accent pl-6" set:html={subtitle} />
            )}

            <div class="pt-8 flex flex-wrap gap-6">
              <a href={buttonHref} class="group relative inline-flex items-center justify-center px-8 py-4 sm:px-10 sm:py-5 bg-accent text-primary font-black text-sm uppercase tracking-widest transition-all">
                <span class="relative z-10">{buttonText}</span>
                <div class="absolute inset-0 bg-white translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
              </a>
              
              {trustIndicators && (
                <div class="flex flex-col justify-center">
                  <div class="flex gap-1 mb-1">
                    {[1,2,3,4,5].map(() => <div class="w-3 h-3 bg-accent"></div>)}
                  </div>
                  <span class="text-[10px] font-black uppercase tracking-widest text-white/80">Trusted across {getLocationText("{city}")}</span>
                </div>
              )}
            </div>
          </div>
        </div>

        <div class="md:col-span-5 hidden md:block relative self-center px-8">
           <div class="absolute inset-0 border-[12px] border-white/10 translate-x-4 translate-y-4 max-w-[450px] aspect-square mx-auto"></div>
           {image ? (
             <div class="relative w-full aspect-square max-w-[450px] mx-auto border-4 border-accent shadow-[20px_20px_0px_rgba(0,0,0,0.2)]">
               <img src={image} alt={title} class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" />
               <div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
             </div>
           ) : (
             <div class="w-full aspect-square max-w-[450px] mx-auto bg-muted border-4 border-accent"></div>
           )}
        </div>
      </div>
    </div>

    {/* Huge background text */}
    <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 pointer-events-none select-none opacity-[0.09]" aria-hidden="true">
      <span class="text-[30vw] font-black uppercase text-white tracking-tighter">{title.split(' ')[0]}</span>
    </div>
  </section>
) : variant === "category" ? (
  <section class="relative bg-card py-20 md:py-32 overflow-hidden border-b-4 border-primary">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-primary/5 -skew-x-12 translate-x-1/2"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          {badge && (
            <span class="inline-block bg-primary text-white text-[10px] font-black px-4 py-1.5 uppercase tracking-[0.3em]">
              {badge}
            </span>
          )}
          <h1 class="text-6xl md:text-8xl font-black text-foreground leading-none tracking-tighter uppercase">
            {title}
          </h1>
          {subtitle && (
            <p class="text-xl md:text-2xl text-muted-foreground font-medium border-l-4 border-primary pl-8" set:html={subtitle} />
          )}
          <a href={buttonHref} class="group relative inline-flex items-center justify-center px-12 py-6 bg-primary text-white font-black text-xs uppercase tracking-[0.2em] transition-all">
            <span class="relative z-10">{buttonText}</span>
            <div class="absolute inset-0 bg-accent translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
          </a>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 border-4 border-accent/20 translate-x-4 translate-y-4"></div>
          {image ? (
            <div class="relative border-4 border-primary shadow-2xl">
              <img src={image} alt={title} class="w-full aspect-[4/3] object-cover" />
            </div>
          ) : (
            <div class="aspect-[4/3] bg-muted border-4 border-primary"></div>
          )}
        </div>
      </div>
    </div>
  </section>
) : slides.length > 0 ? (
  <section class="hero-slideshow relative overflow-hidden bg-primary" style="min-height: 90vh;">
    {/* Background images layer */}
    {slides.map((slide, i) => (
      <div
        class:list={[
          "hero-bg absolute inset-0 transition-all duration-1000",
          i === 0 ? "opacity-100 scale-100" : "opacity-0 scale-105"
        ]}
        data-bg-index={i}
      >
        <img
          src={slide.image}
          alt={slide.title}
          class="absolute inset-0 w-full h-full object-cover grayscale opacity-40"
          loading={i === 0 ? "eager" : "lazy"}
        />
        <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent"></div>
      </div>
    ))}

    <div class="relative z-10 container mx-auto px-4 pt-16 pb-8 md:pt-24 md:pb-12">
      <div class="grid lg:grid-cols-12 gap-12 items-center min-h-[600px]">
        
        {/* Left: Content Area */}
        <div class="lg:col-span-7 relative min-h-[500px] flex flex-col justify-center">
          {slides.map((slide, i) => (
            <div
              class:list={[
                "hero-text absolute inset-0 flex flex-col justify-center transition-all duration-700",
                i === 0 ? "opacity-100 translate-x-0 z-10 pointer-events-auto" : "opacity-0 -translate-x-12 z-0 pointer-events-none"
              ]}
              data-text-index={i}
            >
              <div class="space-y-6">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-1 bg-accent"></div>
                  <span class="text-[10px] font-black uppercase tracking-[0.4em] text-accent">{badge_processed || "Premium Services"}</span>
                </div>
                
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[0.9] tracking-tighter uppercase text-balance">
                  {slide.title}
                </h1>

                {slide.subtitle && (
                  <p class="text-lg md:text-xl text-white/70 max-w-lg font-medium leading-relaxed border-l-4 border-white/20 pl-8">
                    {slide.subtitle}
                  </p>
                )}

                <div class="pt-4">
                  <a
                    href={buttonHref}
                    class="group relative inline-flex items-center justify-center px-12 py-6 bg-accent text-primary font-black text-xs uppercase tracking-[0.2em] transition-all"
                  >
                    <span class="relative z-10">{slide.buttonText || buttonText}</span>
                    <div class="absolute inset-0 bg-white translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>

        {/* Right: Sharp Promo Card */}
        <div class="lg:col-span-5 hidden lg:flex justify-center relative min-h-[450px]">
          {slides.map((slide, i) => (
            slide.promoTitle && (
              <div
                class:list={[
                  "hero-promo absolute inset-0 flex items-center justify-center transition-all duration-700",
                  i === 0 ? "opacity-100 scale-100 rotate-0 z-10 pointer-events-auto" : "opacity-0 scale-90 rotate-3 z-0 pointer-events-none"
                ]}
                data-promo-index={i}
              >
                <div class="relative w-full max-w-[380px]">
                  {/* Brutalist Shadow Offset */}
                  <div class="absolute inset-0 bg-accent translate-x-6 translate-y-6"></div>
                  
                  <div class="relative bg-white border-4 border-primary p-8 space-y-6">
                    <div class="flex justify-between items-start">
                      <div class="bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-widest">
                        Flash Deal
                      </div>
                      <div class="text-[10px] font-black uppercase text-primary/70 tracking-tighter">Verified Offer</div>
                    </div>

                    <div class="space-y-2">
                      <h2 class="text-5xl font-black text-primary leading-none tracking-tighter uppercase">
                        {slide.promoTitle}
                      </h2>
                      <p class="text-sm font-black text-primary uppercase tracking-widest">Limited Availability</p>
                    </div>

                    <div class="h-px bg-primary/10"></div>

                    <p class="text-base font-bold text-primary leading-relaxed uppercase tracking-tight">
                      {slide.promoText}
                    </p>

                    <div class="pt-4 flex items-center justify-between">
                       <div class="space-y-1">
                          <span class="block text-[8px] font-black uppercase text-primary/70">Coupon Code</span>
                          <span class="block text-sm font-black uppercase tracking-widest text-primary">SAVE-TODAY</span>
                       </div>
                       <div class="w-12 h-12 bg-primary/5 flex items-center justify-center border-2 border-primary/20">
                          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                       </div>
                    </div>
                  </div>
                </div>
              </div>
            )
          ))}
        </div>
      </div>

      {/* Sharp Progress Indicators */}
      {hasSlideshow && (
        <div class="hero-progress flex gap-4 mt-12 max-w-md">
          {slides.map((_, i) => (
            <button
              type="button"
              class="hero-progress-bar group relative h-2 flex-1 bg-white/10 overflow-hidden cursor-pointer"
              data-progress-index={i}
              aria-label={`Go to slide ${i + 1}`}
            >
              <div
                class:list={[
                  "hero-fill absolute inset-0 bg-accent transition-all",
                  i === 0 ? "w-0 animate-hero-fill" : "w-0"
                ]}
                data-fill-index={i}
              ></div>
            </button>
          ))}
        </div>
      )}
    </div>

    {/* Massive Vertical Label */}
    <div class="absolute top-0 right-0 bottom-0 w-24 border-l-2 border-white/10 hidden xl:flex items-center justify-center">
      <span class="rotate-90 text-[10px] font-black text-white/30 uppercase tracking-[1em] whitespace-nowrap">
        Professional Plumbing Systems & Infrastructure
      </span>
    </div>
  </section>
) : (
  <section class="relative bg-card py-20 md:py-32 border-b-4 border-primary overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
           <h1 class="text-6xl md:text-8xl font-black text-foreground leading-none tracking-tighter uppercase">{title}</h1>
           <a href={buttonHref} class="group relative inline-flex items-center justify-center px-12 py-6 bg-primary text-white font-black text-xs uppercase tracking-[0.2em] transition-all">
            <span class="relative z-10">{buttonText}</span>
            <div class="absolute inset-0 bg-accent translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
          </a>
        </div>
        <div>
           {image && <img src={image} alt={title} class="w-full border-4 border-primary shadow-2xl" />}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  @keyframes hero-fill {
    from { width: 0%; }
    to { width: 100%; }
  }
  .animate-hero-fill {
    animation: hero-fill 5s linear forwards;
  }
</style>

{hasSlideshow && (
  <script>
    function initHeroSlideshow() {
      const bgs = document.querySelectorAll<HTMLElement>('.hero-bg');
      const texts = document.querySelectorAll<HTMLElement>('.hero-text');
      const promos = document.querySelectorAll<HTMLElement>('.hero-promo');
      const fills = document.querySelectorAll<HTMLElement>('.hero-fill');
      const bars = document.querySelectorAll<HTMLButtonElement>('.hero-progress-bar');

      if (bgs.length < 2) return;

      let current = 0;
      const total = bgs.length;
      const duration = 5000;
      let timer: ReturnType<typeof setTimeout>;

      function goTo(index: number) {
        // Background crossfade
        bgs.forEach((bg, i) => {
          bg.classList.toggle('opacity-100', i === index);
          bg.classList.toggle('opacity-0', i !== index);
        });

        // Text slide
        texts.forEach((t, i) => {
          if (i === index) {
            t.classList.remove('opacity-0', '-translate-x-12', 'z-0', 'pointer-events-none');
            t.classList.add('opacity-100', 'translate-x-0', 'z-10', 'pointer-events-auto');
          } else {
            t.classList.remove('opacity-100', 'translate-x-0', 'z-10', 'pointer-events-auto');
            t.classList.add('opacity-0', '-translate-x-12', 'z-0', 'pointer-events-none');
          }
        });

        // Promo box
        promos.forEach((p, i) => {
          if (i === index) {
            p.classList.remove('opacity-0', 'scale-90', 'rotate-3', 'z-0', 'pointer-events-none');
            p.classList.add('opacity-100', 'scale-100', 'rotate-0', 'z-10', 'pointer-events-auto');
          } else {
            p.classList.remove('opacity-100', 'scale-100', 'rotate-0', 'z-10', 'pointer-events-auto');
            p.classList.add('opacity-0', 'scale-90', 'rotate-3', 'z-0', 'pointer-events-none');
          }
        });

        // Progress fills
        fills.forEach((f, i) => {
          f.classList.remove('animate-hero-fill');
          f.style.width = i < index ? '100%' : '0%';
          if (i === index) {
            // Force reflow to restart animation
            void f.offsetWidth;
            f.style.width = '';
            f.classList.add('animate-hero-fill');
          }
        });

        current = index;
      }

      function next() {
        goTo((current + 1) % total);
        scheduleNext();
      }

      function scheduleNext() {
        clearTimeout(timer);
        timer = setTimeout(next, duration);
      }

      // Click on progress bars
      bars.forEach((bar) => {
        bar.addEventListener('click', () => {
          const idx = Number(bar.dataset.progressIndex);
          goTo(idx);
          scheduleNext();
        });
      });

      // Start autoplay
      scheduleNext();
    }

    document.addEventListener('astro:page-load', initHeroSlideshow);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSlideshow);
    } else {
      initHeroSlideshow();
    }
  </script>
)}
