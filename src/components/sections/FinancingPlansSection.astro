---
import { getLocationText } from "@/config/site";

import {
	Percent,
	CircleDollarSign,
	Calendar,
	CheckCircle,
	Home,
	Building2,
	Wrench,
	Settings,
	ArrowRight,
	MapPin,
	Clock,
} from "lucide-react";

interface Item {
	title: string;
	text?: string;
	href?: string;
	icon?: string;
	image?: string;
}

interface Props {
	badge?: string;
	title: string;
	subtitle?: string;
	items: Item[];
	variant?: "plans" | "services" | "features";
}

const {
	badge: raw_badge,
	title: raw_title,
	subtitle: raw_subtitle,
	items,
	variant = "plans",
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const subtitle = raw_subtitle ? getLocationText(raw_subtitle) : raw_subtitle;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;

const iconMap = {
	percent: Percent,
	zero: CircleDollarSign,
	calendar: Calendar,
	check: CheckCircle,
	home: Home,
	building: Building2,
	wrench: Wrench,
	settings: Settings,
	map: MapPin,
	clock: Clock,
};

const defaultIcon = variant === "services" ? Wrench : CheckCircle;
---

{
	variant === "features" ? (
		<section class="py-24 md:py-32 bg-white relative overflow-hidden">
			<div class="container mx-auto px-4 relative z-10">
				<div class="mb-16 md:mb-24 space-y-6">
					<div class="flex items-center gap-4">
						<span class="bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
							System Features
						</span>
						<div class="h-px flex-grow bg-primary/10" />
					</div>
					<h2 class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-none max-w-4xl">
						{title}
					</h2>
					{subtitle && (
						<p
							class="text-lg font-bold text-primary/60 uppercase tracking-tight max-w-2xl"
							set:html={subtitle}
						/>
					)}
				</div>

				<div class="grid md:grid-cols-3 gap-8">
					{items.map((item, index) => {
						const IconComponent =
							iconMap[item.icon as keyof typeof iconMap] ||
							CheckCircle;
						return (
							<div class="group relative bg-white border-4 border-primary p-10 transition-all duration-300 hover:shadow-[12px_12px_0px_var(--accent)] hover:-translate-x-2 hover:-translate-y-2">
								<div class="w-16 h-16 bg-primary text-white flex items-center justify-center mb-8 border-2 border-primary group-hover:bg-accent group-hover:text-primary transition-all">
									<IconComponent className="w-8 h-8" />
								</div>
								<div class="space-y-4">
									<div class="text-[10px] font-black text-primary/30 uppercase tracking-widest">
										Node-
										{String(index + 1).padStart(2, "0")}
									</div>
									<h3 class="text-xl font-black text-primary uppercase tracking-tight leading-tight">
										{item.title}
									</h3>
									{item.text && (
										<p
											class="text-sm font-bold text-primary/60 uppercase leading-relaxed tracking-tight"
											set:html={item.text}
										/>
									)}
								</div>
							</div>
						);
					})}
				</div>
			</div>
		</section>
	) : variant === "services" ? (
		<section
			class="py-24 md:py-32 bg-white relative overflow-hidden"
			style="border-bottom: 3px solid var(--brand-primary, #45f9ff);">
			{/* Technical Background */}
			<div class="absolute inset-0 opacity-[0.03] pointer-events-none" />

			<div class="container mx-auto px-4 relative z-10">
				<div class="mb-16 md:mb-24 space-y-6 text-center">
					<h2 class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-none mx-auto max-w-4xl">
						{title}
					</h2>
					<div class="w-24 h-2 bg-accent mx-auto" />
					{subtitle && (
						<p
							class="text-lg font-bold text-primary/60 uppercase tracking-tight max-w-2xl mx-auto"
							set:html={subtitle}
						/>
					)}
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
					{items.map((item, index) => {
						return (
							<div class="group bg-white border-4 border-primary transition-all duration-300 hover:shadow-[12px_12px_0px_var(--accent)] hover:-translate-x-2 hover:-translate-y-2">
								{item.image && (
									<div class="relative h-48 overflow-hidden border-b-4 border-primary">
										<img
											src={item.image}
											alt={item.title}
											class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110"
										/>
										<div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-colors" />
										<div class="absolute top-0 left-0 bg-primary text-white font-black text-[10px] px-3 py-1">
											ASSET-
											{String(index + 1).padStart(2, "0")}
										</div>
									</div>
								)}
								<div class="p-8 text-center space-y-4">
									<h3 class="text-lg font-black text-primary uppercase tracking-tight leading-tight">
										{item.title}
									</h3>
									{item.text && (
										<p
											class="text-xs font-bold text-primary/60 uppercase leading-relaxed tracking-tight"
											set:html={item.text}
										/>
									)}
								</div>
							</div>
						);
					})}
				</div>
			</div>
		</section>
	) : (
		<section class="py-24 md:py-32 bg-white relative overflow-hidden">
			{/* Technical Background */}
			<div
				class="absolute inset-0 opacity-[0.03] pointer-events-none"
				style="background-image: radial-gradient(var(--brand-primary, #45f9ff) 2px, transparent 0); background-size: 30px 30px;"
			/>

			<div class="container mx-auto px-4 relative z-10">
				<div class="mb-16 md:mb-24 space-y-6">
					<div class="flex items-center gap-4">
						<span class="bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
							Strategic Resource
						</span>
						<div class="h-px flex-grow bg-primary/10" />
					</div>
					<h2 class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-none">
						{title}
					</h2>
					{subtitle && (
						<p
							class="text-lg text-muted-foreground leading-relaxed font-medium"
							set:html={subtitle}
						/>
					)}
				</div>

				<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
					{items.map((item, index) => {
						const IconComponent =
							iconMap[item.icon as keyof typeof iconMap] ||
							defaultIcon;
						return (
							<div class="group bg-white border-4 border-primary p-8 transition-all duration-300 hover:shadow-[12px_12px_0px_var(--accent)] hover:-translate-x-2 hover:-translate-y-2">
								<div class="w-14 h-14 bg-primary text-white flex items-center justify-center mb-6 border-2 border-primary group-hover:bg-accent group-hover:text-primary transition-all">
									<IconComponent className="w-6 h-6" />
								</div>
								<div class="space-y-4">
									<div class="text-[10px] font-black text-primary/30 uppercase tracking-widest leading-none">
										Resource-
										{String(index + 1).padStart(2, "0")}
									</div>
									<h3 class="text-lg font-black text-primary uppercase tracking-tight leading-tight">
										{item.title}
									</h3>
									{item.text && (
										<p
											class="text-xs font-bold text-primary/60 uppercase leading-relaxed tracking-tight"
											set:html={item.text}
										/>
									)}
								</div>
							</div>
						);
					})}
				</div>
			</div>
		</section>
	)
}
