---
import { Check, Wallet } from "@lucide/astro";
import { getLocationText } from "@/config/site";

interface Props {
	title: string;
	description: string;
	subtitle?: string;
	benefits?: string[];
}

const {
	title: raw_title,
	description: raw_description,
	subtitle: raw_subtitle,
	benefits = [],
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description
	? getLocationText(raw_description)
	: raw_description;
const subtitle = raw_subtitle ? getLocationText(raw_subtitle) : raw_subtitle;
---

<section
	class="py-24 md:py-32 bg-white relative overflow-hidden border-b-4 border-primary">
	{/* Technical Background */}
	<div
		class="absolute inset-0 opacity-[0.03] pointer-events-none"
		style="background-image: radial-gradient(var(--brand-primary, #000) 2px, transparent 0); background-size: 30px 30px;">
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="max-w-5xl mx-auto">
			<div class="mb-16" data-animate="fade-up">
				<h2
					class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-[1.1] mb-6">
					{title}
				</h2>
				<div class="w-16 h-1.5 bg-accent mb-6"></div>
				<p
					class="text-lg font-medium tracking-tight text-primary max-w-2xl"
					set:html={description}
				/>
			</div>

			{
				subtitle && benefits.length > 0 && (
					<div
						class="bg-white border-4 border-primary p-10 shadow-[16px_16px_0px_var(--brand-secondary,rgba(0,0,0,0.1))] hover:shadow-[16px_16px_0px_var(--accent)] transition-all duration-500 relative group"
						data-animate="fade-up">
						<div class="absolute top-0 right-10 bg-primary text-white text-[10px] font-black px-4 py-1 uppercase tracking-widest">
							Capital_Incentives
						</div>

						<div class="flex items-center gap-4 mb-10">
							<Wallet class="w-8 h-8 text-accent" />
							<h3 class="text-2xl font-black text-primary uppercase tracking-tight">
								{subtitle}
							</h3>
						</div>

						<ul class="grid sm:grid-cols-2 gap-x-12 gap-y-6">
							{benefits.map((benefit) => (
								<li class="flex items-start gap-4">
									<div class="w-6 h-6 bg-primary text-white flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-accent group-hover:text-primary transition-colors">
										<Check class="w-4 h-4 stroke-[4px]" />
									</div>
									<span class="text-sm font-bold uppercase tracking-tight text-primary/80 group-hover:text-primary transition-colors leading-tight">
										{benefit}
									</span>
								</li>
							))}
						</ul>
					</div>
				)
			}
		</div>
	</div>
</section>
