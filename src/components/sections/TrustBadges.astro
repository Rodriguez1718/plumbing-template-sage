---
interface Props {
  badges?: Array<{ name: string; color?: string; rating?: string }>;
}

const { badges = [
  { name: "Yelp", color: "text-red-600" },
  { name: "nextdoor", color: "text-green-600" },
  { name: "Google", rating: "★★★★★" }
] } = Astro.props;
---

<section class="py-12 bg-muted/50">
  <div class="container mx-auto px-4">
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16">
      {badges.map((badge) => (
        <div class="flex items-center gap-2">
          <span class={`text-2xl font-bold ${badge.color || ''}`}>{badge.name}</span>
          {badge.rating && <div class="flex text-yellow-500">{badge.rating}</div>}
        </div>
      ))}
    </div>
  </div>
</section>
