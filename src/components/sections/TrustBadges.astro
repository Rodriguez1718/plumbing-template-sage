---
interface Badge {
  name: string;
  image: string;
  alt?: string;
  small?: boolean;
}

interface Props {
  badges?: Badge[];
}

const { badges = [
  { name: "BBB & Angie's List", image: "/images/trust-badges/BBB_Angies-List.webp" },
  { name: "Google Reviews", image: "/images/trust-badges/google-review.webp" },
  { name: "Nextdoor", image: "/images/trust-badges/Nextdoor-logo.webp", small: true },
  { name: "HomeAdvisor", image: "/images/trust-badges/HomeAdvisor.webp" },
  { name: "BBB A+", image: "/images/trust-badges/bbb-logo-a-plus.webp" },
  { name: "Google Reviews 2", image: "/images/trust-badges/google-review.webp" },
] } = Astro.props;

// Triple the badges for extra smooth seamless loop
const duplicatedBadges = [...badges, ...badges, ...badges];
---

<section class="py-12 bg-white relative overflow-hidden border-y-4 border-primary/10">
  {/* Technical Background */}
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--brand-primary, #45f9ff) 2px, transparent 0); background-size: 20px 20px;"></div>

  <div class="container mx-auto px-4 mb-6 relative z-10">
    <div class="flex items-center gap-4">
      <span class="inline-block bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
        Verified Status
      </span>
      <div class="h-px flex-grow bg-primary/10"></div>
    </div>
  </div>

  <div class="carousel-container relative z-10">
    <div class="carousel-track">
      {duplicatedBadges.map((badge) => (
        <div class="carousel-item group">
          <img 
            src={badge.image} 
            alt={badge.alt || badge.name}
            class={`trust-logo ${badge.small ? 'small' : ''}`}
            width={badge.small ? 70 : 120}
            height={badge.small ? 35 : 50}
            loading="eager"
            decoding="async"
            fetchpriority="low"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-container {
    width: 100%;
    overflow: hidden;
    /* Industrial sharp fade effect */
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: 6rem;
    width: max-content;
    animation: scroll 30s linear infinite;
    will-change: transform;
  }

  .carousel-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .carousel-item:hover {
    transform: scale(1.1);
  }

  .trust-logo {
    height: 45px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.5) contrast(1.2);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .carousel-item:hover .trust-logo {
    filter: grayscale(0) opacity(1) contrast(1);
  }

  .trust-logo.small {
    height: 30px;
  }

  @keyframes scroll {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(calc(-100% / 3), 0, 0);
    }
  }

  @media (min-width: 768px) {
    .carousel-track {
      gap: 8rem;
    }
    
    .trust-logo {
      height: 55px;
    }

    .trust-logo.small {
      height: 38px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none;
    }
  }
</style>
