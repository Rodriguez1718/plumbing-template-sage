---
import { getLocationText } from "@/config/site"

interface FAQItem {
  question: string;
  answer?: string;
}

interface Props {
  title: string;
  faqs: FAQItem[];
}

const { title: raw_title, faqs: rawFaqs } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : "";
const faqs = rawFaqs.map(faq => ({
  ...faq,
  question: getLocationText(faq.question),
  answer: faq.answer ? getLocationText(faq.answer) : undefined,
}));
---

<section class="py-24 md:py-32 bg-white relative overflow-hidden">
  {/* Technical Background */}
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--brand-primary, #45f9ff) 2px, transparent 0); background-size: 30px 30px;"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto">
      {/* Header */}
      <div class="mb-16 space-y-6">
        <div class="flex items-center gap-4">
          <span class="bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
            Knowledge Base
          </span>
          <div class="h-px flex-grow bg-primary/10"></div>
        </div>
        <h2 class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-none">
          {title}
        </h2>
      </div>
      
      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details class="group relative bg-white border-4 border-primary transition-all duration-300 open:shadow-[8px_8px_0px_var(--accent)]">
            <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
              <div class="flex items-start gap-6">
                <span class="text-[10px] font-black text-primary/30 uppercase mt-1">
                  Q-{String(index + 1).padStart(2, '0')}
                </span>
                <span class="text-lg md:text-xl font-black uppercase tracking-tight text-primary leading-tight group-hover:text-accent transition-colors pr-8">
                  {faq.question}
                </span>
              </div>
              <div class="shrink-0 w-10 h-10 bg-primary text-white flex items-center justify-center border-2 border-primary group-open:bg-accent group-open:text-primary transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="square" stroke-linejoin="round" class="group-open:rotate-180 transition-transform">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </div>
            </summary>
            {faq.answer && (
              <div class="px-6 md:px-8 pb-8 pt-2">
                <div class="p-6 bg-primary/5 border-l-4 border-accent">
                  <p class="text-base font-bold text-primary/70 uppercase leading-relaxed tracking-tight" set:html={faq.answer} />
                </div>
              </div>
            )}
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
