---
import { getLocationText } from "@/config/site";

interface IncludedItem {
	title: string;
	description: string;
}

interface Props {
	title: string;
	description: string;
	includedItems: IncludedItem[];
	benefits: string[];
	buttonText?: string;
	buttonHref?: string;
}

const {
	title: raw_title,
	description: raw_description,
	includedItems,
	benefits,
	buttonText = "LEARN MORE",
	buttonHref = "/maintenance-plans",
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description
	? getLocationText(raw_description)
	: raw_description;
---

<section class="py-20 md:py-32 bg-card relative overflow-hidden">
	<!-- Background Geometric Pattern -->
	<div
		class="absolute inset-0 opacity-[0.03] pointer-events-none"
		style="background-image: radial-gradient(var(--brand-primary, #45f9ff) 1px, transparent 0); background-size: 40px 40px;">
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div
			class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8"
			data-animate="fade-up">
			<div class="max-w-3xl space-y-4">
					class="inline-block bg-accent text-primary text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
					Long-Term Value
				</span>
				<h2
					class="text-4xl md:text-6xl font-black text-foreground leading-none tracking-tighter uppercase">
					Priority <br /><span class="text-primary">Maintenance</span> Plans
				</h2>
				<p
					class="text-lg text-foreground/80 font-medium max-w-2xl leading-relaxed"
					set:html={description}
				/>
			</div>
			<div class="hidden md:block w-24 h-1 bg-accent"></div>
		</div>

		<div
			class="grid lg:grid-cols-12 gap-10 lg:gap-0 items-stretch"
			data-animate-stagger>
			<!-- Included Items Card -->
			<div
				class="lg:col-span-7 bg-card border-4 border-primary p-8 md:p-12 z-10 shadow-[12px_12px_0px_rgba(0,0,0,0.05)]">
				<div class="space-y-8">
					<div class="space-y-2">
						<h3
							class="text-xl md:text-2xl font-black uppercase tracking-tight text-primary">
							What's Included?
						</h3>
						<p
							class="text-xs font-bold text-foreground/80 uppercase tracking-widest">
							Comprehensive checkups & protection
						</p>
					</div>

					<ul class="grid md:grid-cols-2 gap-x-8 gap-y-6">
						{
							includedItems.map((item) => (
								<li class="flex items-start gap-4 group">
									<div class="mt-1 w-6 h-6 flex-shrink-0 flex items-center justify-center bg-primary text-white group-hover:bg-accent group-hover:text-accent-foreground transition-colors">
										<svg
											class="w-4 h-4"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="3"
												d="M5 13l4 4L19 7"
											/>
										</svg>
									</div>
									<div>
										<span class="block text-sm font-black uppercase tracking-tight mb-1">
											{item.title}
										</span>
										<p
											class="text-xs text-foreground/80 leading-relaxed font-medium"
											set:html={item.description}
										/>
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</div>

			<!-- Benefits / Highlight Card -->
			<div
				class="lg:col-span-5 bg-primary text-white p-8 md:p-12 relative overflow-visible shadow-[20px_20px_0px_var(--accent)] lg:-translate-x-4 lg:translate-y-8">
				<div class="space-y-8">
					<div class="space-y-2">
						<h3
							class="text-xl md:text-2xl font-black uppercase tracking-tight text-accent">
							Member Benefits
						</h3>
						<p
							class="text-xs font-bold text-white/60 uppercase tracking-widest">
							Why invest in a plan today?
						</p>
					</div>

					<ul class="space-y-5">
						{
							benefits.map((benefit) => (
								<li class="flex items-center gap-4 group">
									<div class="w-2 h-2 bg-accent" />
									<span class="text-sm font-bold uppercase tracking-wide group-hover:text-accent transition-colors">
										{benefit}
									</span>
								</li>
							))
						}
					</ul>

					<div class="pt-6">
						<a
							href={buttonHref}
							class="group relative inline-flex items-center justify-center w-full py-4 bg-white text-primary font-black text-xs uppercase tracking-widest transition-all hover:-translate-x-1 hover:-translate-y-1">
							<span class="relative z-10">{buttonText}</span>
							<div
								class="absolute inset-0 bg-accent translate-x-0 translate-y-0 -z-10 group-hover:translate-x-2 group-hover:translate-y-2 transition-all">
							</div>
						</a>
					</div>
				</div>

				<!-- Sharp decorative corner -->
				<div class="absolute top-0 right-0 w-12 h-12 bg-accent/20">
				</div>
			</div>
		</div>
	</div>
</section>
