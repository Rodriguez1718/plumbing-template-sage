---
import { getLocationText } from "@/config/site";

interface ServiceCard {
	image: string;
	icon: string;
	title: string;
	href?: string;
}

interface Props {
	title: string;
	description?: string;
	services: ServiceCard[];
}

const {
	title: raw_title,
	description: raw_description,
	services,
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description
	? getLocationText(raw_description)
	: raw_description;

const iconMap: Record<string, string> = {
	kitchen: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`,
	bathroom: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" x2="8" y1="5" y2="7"/><line x1="2" x2="22" y1="12" y2="12"/><line x1="7" x2="7" y1="19" y2="21"/><line x1="17" x2="17" y1="19" y2="21"/></svg>`,
	leak: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`,
	waterheater: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12c-2-2.67-4-4-4-5.5a4 4 0 1 1 8 0c0 1.5-2 2.83-4 5.5Z"/><path d="M12 22v-4"/><path d="M12 14v-2"/><rect x="6" y="14" width="12" height="8" rx="2"/></svg>`,
	drain: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16"/><path d="M4 22V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v18"/><path d="M12 6v4"/><path d="M12 14v4"/><circle cx="12" cy="12" r="2"/></svg>`,
	pipe: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 6 4-4 4 4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg>`,
};
---

<section
	class="py-24 md:py-32 bg-white relative overflow-hidden"
	style="border-bottom: 3px solid var(--brand-primary, #45f9ff);">
	<div class="container mx-auto px-4 relative z-10">
		{/* Header */}
		<div class="mb-16 md:mb-24 space-y-6">
			<div class="flex items-center gap-4">
				<span
					class="bg-accent text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
					Service Catalog
				</span>
			</div>
			<h2
				class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-none max-w-4xl">
				{title}
			</h2>
			<div class="w-16 h-1.5 bg-accent"></div>
			{
				description && (
					<p
						class="text-lg text-muted-foreground leading-relaxed font-medium"
						set:html={description}
					/>
				)
			}
		</div>

		{/* Services Grid */}
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			{
				services.map((service, index) => (
					<a href={service.href || "#"} class="group block relative">
						<div class="relative bg-white border-4 border-primary transition-all duration-300 group-hover:shadow-[12px_12px_0px_var(--accent)] group-hover:-translate-x-2 group-hover:-translate-y-2">
							{/* Image Container */}
							<div class="relative h-[250px] overflow-hidden border-b-4 border-primary">
								<img
									src={service.image}
									alt={service.title}
									class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110"
								/>
								<div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-colors" />

								{/* Service Index */}
								<div class="absolute top-0 right-0 bg-primary text-white font-black text-xs px-4 py-2">
									MOD-{String(index + 1).padStart(2, "0")}
								</div>
							</div>

							{/* Content */}
							<div class="p-8 space-y-6">
								<div class="flex items-start justify-between gap-4">
									<h3 class="text-xl font-black text-primary uppercase tracking-tight leading-tight group-hover:text-accent transition-colors">
										{service.title}
									</h3>
									<div
										class="w-12 h-12 flex-shrink-0 bg-primary text-white flex items-center justify-center border-2 border-primary group-hover:bg-accent group-hover:text-primary transition-all"
										set:html={
											iconMap[service.icon] ||
											iconMap["pipe"]
										}
									/>
								</div>

								<div class="pt-6 border-t border-primary/10 flex items-center justify-between">
									<span class="text-[10px] font-black uppercase tracking-widest text-primary/70 group-hover:text-primary transition-colors">
										Initialize Request
									</span>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="w-5 h-5 translate-x-[-10px] opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all text-accent"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="3"
										stroke-linecap="square"
										stroke-linejoin="round">
										<line x1="5" y1="12" x2="19" y2="12" />
										<polyline points="12 5 19 12 12 19" />
									</svg>
								</div>
							</div>
						</div>
					</a>
				))
			}
		</div>
	</div>
</section>
