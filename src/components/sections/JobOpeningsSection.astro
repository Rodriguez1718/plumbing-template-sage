---
import { Briefcase, Target, ChevronRight, Settings } from "@lucide/astro";
import { getLocationText } from "@/config/site"

interface JobOpening {
  title: string;
  type?: string;
  responsibilities: string;
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  jobs: JobOpening[];
  introTitle?: string;
  introDescription?: string;
}

const { badge: raw_badge, title: raw_title, description: raw_description, jobs, introTitle: raw_introTitle, introDescription: raw_introDescription } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const introTitle = raw_introTitle ? getLocationText(raw_introTitle) : raw_introTitle;
const introDescription = raw_introDescription ? getLocationText(raw_introDescription) : raw_introDescription;
---

<section class="py-24 md:py-32 bg-white relative overflow-hidden border-b-4 border-primary">
  {/* Technical Background */}
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--brand-primary, #000) 2px, transparent 0); background-size: 30px 30px;"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-6xl mx-auto">
      {introTitle && (
        <div class="mb-20" data-animate="fade-up">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-1 bg-accent"></div>
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-primary/70">Recruitment_Protocol_V2</span>
          </div>
          <h2 class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-[1.1] mb-8">{introTitle}</h2>
          {introDescription && <p class="text-lg font-medium leading-relaxed text-primary max-w-2xl" set:html={introDescription} />}
        </div>
      )}

      <div class="mb-16 md:mb-24" data-animate="fade-up">
        <div class="flex items-center gap-4 mb-4">
          <Settings class="w-5 h-5 text-accent animate-spin-slow" />
          <h3 class="text-2xl font-black text-primary uppercase tracking-tight">{title}</h3>
        </div>
        {description && <p class="text-lg font-medium text-primary/70 max-w-3xl" set:html={description} />}
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12" data-animate-stagger>
        {jobs.map((job) => (
          <div class="group relative bg-white border-4 border-primary p-8 shadow-[12px_12px_0px_var(--brand-secondary,rgba(0,0,0,0.1))] hover:shadow-[16px_16px_0px_var(--accent)] transition-all duration-500 flex flex-col h-full rounded-none">
            <div class="absolute top-0 right-8 bg-primary text-white text-[10px] font-black px-4 py-1 uppercase tracking-widest">
              STATUS: OPEN
            </div>
            
            <div class="mb-8">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 bg-primary text-white flex items-center justify-center group-hover:bg-accent group-hover:text-primary transition-colors">
                  <Briefcase class="w-4 h-4 stroke-[3px]" />
                </div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-primary/70">Operational_Role</span>
              </div>
              <h3 class="text-2xl font-black text-primary uppercase tracking-tighter leading-tight group-hover:text-accent transition-colors">{job.title}</h3>
              <p class="text-xs font-black text-accent uppercase tracking-widest mt-2">{job.type || "Full-time position"}</p>
            </div>

            <div class="flex-grow space-y-4 mb-10">
              <div class="flex items-center gap-3">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-primary/70">Protocol_Parameters</span>
              </div>
              <p class="text-sm font-bold uppercase tracking-tight text-primary/80 border-t-2 border-dashed border-primary/10 pt-4 leading-relaxed">
                {job.responsibilities}
              </p>
            </div>

            <a 
              href={job.buttonHref || "/contact"} 
              class="w-full inline-flex items-center justify-center bg-primary text-white py-4 px-6 font-black text-xs uppercase tracking-[0.3em] border-2 border-primary hover:bg-accent hover:text-primary transition-all shadow-[4px_4px_0px_rgba(0,0,0,0.1)] gap-3 rounded-none"
            >
              {job.buttonText || "INITIALIZE_APPLICATION"}
              <ChevronRight class="w-4 h-4 stroke-[4px]" />
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .animate-spin-slow {
    animation: spin 8s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
