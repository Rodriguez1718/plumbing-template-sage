---
import { Check, Scissors, Settings } from "@lucide/astro";
import { getLocationText } from "@/config/site";

interface PlanFeature {
	text: string;
}

interface Plan {
	ribbon: string;
	ribbonColor?: "great" | "better" | "best";
	title: string;
	price: string;
	period?: string;
	features: string[];
}

interface Props {
	title: string;
	description: string;
	plans: Plan[];
}

const { title: raw_title, description: raw_description, plans } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description
	? getLocationText(raw_description)
	: raw_description;

const ribbonColors = {
	great: "bg-primary text-white",
	better: "bg-accent text-primary",
	best: "bg-primary text-accent",
};
---

<section
	class="py-24 md:py-32 bg-white relative overflow-hidden border-b-4 border-primary">
	<div class="container mx-auto px-4 relative z-10">
		<div class="max-w-4xl mb-20" data-animate="fade-up">
			<h2
				class="text-4xl md:text-6xl font-black text-foreground leading-[1.1] tracking-tighter uppercase mb-6">
				{title}
			</h2>
			<p
				class="text-lg text-muted-foreground font-medium max-w-2xl leading-relaxed"
				set:html={description}
			/>
		</div>

		<div class="grid lg:grid-cols-3 gap-12" data-animate-stagger>
			{
				plans.map((plan) => (
					<div class="group relative bg-white border-4 border-primary p-10 shadow-[16px_16px_0px_var(--brand-secondary,rgba(0,0,0,0.1))] hover:shadow-[16px_16px_0px_var(--accent)] transition-all duration-500 overflow-visible">
						{/* Perforated Cut-outs (Ticket Aesthetic) */}
						<div class="absolute top-[40%] -left-3.5 w-7 h-7 bg-white border-4 border-primary rounded-full -translate-y-1/2 z-20" />
						<div class="absolute top-[40%] -right-3.5 w-7 h-7 bg-white border-4 border-primary rounded-full -translate-y-1/2 z-20" />

						{/* Header Section */}
						<div class="mb-10 border-b-4 border-dashed border-primary/20 pb-10 relative">
							<div class="absolute -left-10 top-1/2 -translate-y-1/2 text-primary opacity-10 group-hover:opacity-40 transition-opacity">
								<Scissors class="w-4 h-4 rotate-90" />
							</div>

							<div
								class={`inline-block px-4 py-1 text-[10px] font-black uppercase tracking-[0.2em] mb-8 ${ribbonColors[plan.ribbonColor || "great"]}`}>
								{plan.ribbon}
							</div>

							<h3 class="text-4xl font-black text-primary uppercase tracking-tighter leading-none mb-6 group-hover:text-accent transition-colors">
								{plan.title}
							</h3>

							<div class="flex items-baseline gap-1">
								<span class="text-6xl font-black text-primary tracking-tighter">
									{plan.price}
								</span>
								{plan.period && (
									<span class="text-xs font-black uppercase tracking-[0.2em] text-primary/30">
										/ {plan.period}
									</span>
								)}
							</div>
						</div>

						{/* Operations/Features List */}
						<div class="space-y-8">
							<p class="text-[10px] font-black text-primary/30 uppercase tracking-[0.3em] flex items-center gap-2">
								<Settings class="w-3 h-3" />
								Operation_Specs
							</p>
							<ul class="space-y-5">
								{plan.features.map((feature) => (
									<li class="flex items-start gap-4">
										<div class="w-6 h-6 bg-primary text-white flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-accent group-hover:text-primary transition-colors">
											<Check class="w-4 h-4 stroke-[4px]" />
										</div>
										<span class="text-sm font-bold uppercase tracking-tight text-primary/80 group-hover:text-primary transition-colors leading-tight">
											{feature}
										</span>
									</li>
								))}
							</ul>
						</div>

						{/* Action Button */}
						<div class="mt-12">
							<button class="w-full bg-primary text-white px-8 py-6 font-black text-xs uppercase tracking-[0.4em] border-4 border-primary hover:bg-white hover:text-primary transition-all active:translate-y-1 shadow-[8px_8px_0px_rgba(0,0,0,0.1)] group-hover:shadow-none">
								INITIALIZE_MODULE
							</button>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
