---
interface Props {
  title: string;
  description: string;
  areas?: string[];
  mapImage?: string;
  mapEmbed?: string;
  mapAddress?: string;
  variant?: "full" | "compact";
  buttonText?: string;
  buttonHref?: string;
}

const { 
  title, 
  description, 
  areas, 
  mapImage, 
  mapEmbed, 
  mapAddress,
  variant = "full",
  buttonText = "SERVICE AREAS",
  buttonHref = "/service-areas"
} = Astro.props;

// Generate Google Maps embed URL from address if mapEmbed not provided
const getMapEmbedUrl = (address: string) => {
  const encodedAddress = encodeURIComponent(address);
  return `https://www.google.com/maps?q=${encodedAddress}&output=embed`;
};

const embedUrl = mapEmbed || (mapAddress ? getMapEmbedUrl(mapAddress) : null);
---

{variant === "compact" ? (
  <section class="py-16 md:py-24 bg-background">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="order-2 md:order-1">
          {embedUrl ? (
            <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
              <iframe
                src={embedUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Service Area Map"
              ></iframe>
            </div>
          ) : mapImage ? (
            <img src={mapImage} alt="Service Area Map" class="rounded-lg w-full shadow-lg" />
          ) : (
            <div class="aspect-[4/3] bg-muted rounded-lg flex items-center justify-center">
              <span class="text-muted-foreground">Map - Service Area</span>
            </div>
          )}
        </div>
        
        <div class="order-1 md:order-2 text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-bold mb-4">{title}</h2>
          <p class="text-muted-foreground mb-6">{description}</p>
          <a href={buttonHref} class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-6 py-3 font-semibold hover:bg-primary/90 transition-colors">
            {buttonText}
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">{title}</h2>
          <p class="text-muted-foreground mb-8">{description}</p>
          
          {areas && areas.length > 0 && (
            <>
              <h3 class="text-xl font-bold mb-4">Areas We Serve</h3>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm">
                {areas.map((area) => (
                  <span class="text-muted-foreground hover:text-accent transition-colors cursor-default flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/60"></span>
                    {area}
                  </span>
                ))}
              </div>
            </>
          )}
        </div>
        
        <div>
          {embedUrl ? (
            <div class="aspect-square rounded-lg overflow-hidden">
              <iframe
                src={embedUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Service Area Map"
              ></iframe>
            </div>
          ) : mapImage ? (
            <img src={mapImage} alt="Service Area Map" class="rounded-lg w-full" />
          ) : (
            <div class="aspect-square bg-muted rounded-lg flex items-center justify-center">
              <span class="text-muted-foreground">Map - Service Area</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}
