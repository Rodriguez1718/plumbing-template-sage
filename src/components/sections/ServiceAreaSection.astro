---
import { getLocationText, processLocationArray } from "@/config/site";

interface Props {
	title: string;
	description: string;
	areas?: string[];
	mapImage?: string;
	mapEmbed?: string;
	mapAddress?: string;
	variant?: "full" | "compact";
	buttonText?: string;
	buttonHref?: string;
}

const {
	title: rawTitle,
	description: rawDescription,
	areas: rawAreas,
	mapImage,
	mapEmbed,
	mapAddress: rawMapAddress,
	variant = "full",
	buttonText: rawButtonText = "SERVICE AREAS",
	buttonHref = "/service-areas",
} = Astro.props;

// Process all text through getLocationText
const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const areas = rawAreas ? processLocationArray(rawAreas) : undefined;
const mapAddress = rawMapAddress ? getLocationText(rawMapAddress) : undefined;
const buttonText = getLocationText(rawButtonText);

// Generate Google Maps embed URL from address if mapEmbed not provided
const getMapEmbedUrl = (address: string) => {
	const encodedAddress = encodeURIComponent(address);
	return `https://www.google.com/maps?q=${encodedAddress}&output=embed`;
};

const embedUrl = mapEmbed || (mapAddress ? getMapEmbedUrl(mapAddress) : null);
---

{
	variant === "compact" ? (
		<section class="py-20 md:py-32 bg-card relative overflow-hidden">
			{/* Technical Background */}
			<div
				class="absolute inset-0 opacity-[0.03] pointer-events-none"
				style="background-image: radial-gradient(var(--brand-primary, #45f9ff) 2px, transparent 0); background-size: 30px 30px;"
			/>

			<div class="container mx-auto px-4 relative z-10">
				<div class="grid lg:grid-cols-2 gap-10 md:gap-16 items-center max-w-6xl mx-auto">
					<div class="space-y-8">
						<div class="space-y-4">
							<span class="inline-block bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
								Regional Hub
							</span>
							<h2 class="text-4xl md:text-6xl font-black text-foreground leading-none tracking-tighter uppercase">
								Operational{" "}
								<>
									<br />
									<span class="text-primary">Perimeter</span>
								</>
							</h2>
						</div>
						<p
							class="text-lg text-foreground/80 font-medium leading-relaxed border-l-4 border-accent pl-6 md:pl-8"
							set:html={description}
						/>

						<div class="pt-4">
							<a
								href={buttonHref}
								class="group relative inline-flex items-center justify-center px-10 py-5 bg-primary text-white font-black text-xs uppercase tracking-[0.2em] transition-all">
								<span class="relative z-10">{buttonText}</span>
								<div class="absolute inset-0 bg-accent translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform" />
							</a>
						</div>
					</div>

					<div class="relative mt-8 lg:mt-0 mr-4 mb-4">
						{/* Map Frame with Brutalist Shadow */}
						<div class="absolute inset-0 bg-accent translate-x-3 translate-y-3 md:translate-x-4 md:translate-y-4" />
						<div class="relative bg-white border-4 border-primary overflow-hidden shadow-2xl">
							{embedUrl ? (
								<iframe
									src={embedUrl}
									width="100%"
									height="350"
									style="border:0; filter: grayscale(1) contrast(1.1) brightness(0.9);"
									allowfullscreen=""
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
									class="grayscale-map hover:grayscale-0 transition-all duration-700 md:h-[400px]"
								/>
							) : mapImage ? (
								<img
									src={mapImage}
									alt="Service Area Map"
									class="w-full h-[350px] md:h-[400px] object-cover grayscale hover:grayscale-0 transition-all duration-700"
								/>
							) : (
								<div class="h-[350px] md:h-[400px] bg-muted flex items-center justify-center">
									<span class="text-muted-foreground font-black uppercase tracking-widest text-center px-4">
										Digital Perimeter Map
									</span>
								</div>
							)}
						</div>
					</div>
				</div>
			</div>
		</section>
	) : (
		<section
			class="py-20 md:py-32 bg-card relative overflow-hidden"
			style="border-bottom: 3px solid var(--brand-primary, #45f9ff);">
			<div class="container mx-auto px-4 relative z-10">
				<div class="grid lg:grid-cols-12 gap-10 md:gap-16 items-start">
					<div class="lg:col-span-5 space-y-10 md:space-y-12">
						<div class="space-y-4">
							<span class="inline-block bg-primary text-white text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
								Network Coverage
							</span>
							<h2 class="text-4xl md:text-6xl lg:text-7xl font-black text-foreground leading-[0.9] tracking-tighter uppercase">
								Serving the{" "}
								<>
									<br />
									<span class="text-primary">
										Infrastructure
									</span>
								</>
							</h2>
						</div>

						<p
							class="text-lg md:text-xl text-foreground/80 font-medium leading-relaxed max-w-xl"
							set:html={description}
						/>

						{areas && (
							<div class="space-y-6">
								<h3 class="text-xs md:text-sm font-black uppercase tracking-[0.3em] text-primary flex items-center gap-4">
									Active Service Nodes
									<div class="h-px flex-grow bg-primary/10" />
								</h3>
								<div class="grid grid-cols-2 sm:grid-cols-3 gap-2 max-h-[250px] md:max-h-[300px] overflow-y-auto pr-2 custom-scrollbar">
									{areas.map((area) => (
										<div class="group relative bg-white border-2 border-primary/10 p-3 transition-all hover:border-primary hover:shadow-[4px_4px_0px_var(--accent)] hover:-translate-x-1 hover:-translate-y-1">
											<span class="text-[10px] font-black uppercase tracking-widest text-primary/80 group-hover:text-primary transition-colors block truncate">
												{area}
											</span>
										</div>
									))}
								</div>
							</div>
						)}

						<div class="pt-4">
							<a
								href={buttonHref}
								class="group relative inline-flex items-center justify-center px-10 py-5 md:px-12 md:py-6 bg-primary text-white font-black text-xs uppercase tracking-[0.2em] transition-all">
								<span class="relative z-10">{buttonText}</span>
								<div class="absolute inset-0 bg-accent translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform" />
							</a>
						</div>
					</div>

					<div class="lg:col-span-7 relative mt-12 lg:mt-0 mr-6 mb-6 h-full min-h-[350px] md:min-h-[500px]">
						{/* Map Frame with Brutalist Shadow */}
						<div class="absolute inset-0 bg-accent translate-x-3 translate-y-3 md:translate-x-6 md:translate-y-6" />
						<div class="relative h-full bg-white border-4 border-primary shadow-2xl overflow-hidden min-h-[350px] md:min-h-[500px]">
							{embedUrl ? (
								<iframe
									src={embedUrl}
									width="100%"
									height="100%"
									class="absolute inset-0 grayscale-map hover:grayscale-0 transition-all duration-700 h-full w-full min-h-[350px] md:min-h-[500px]"
									style="border:0; filter: grayscale(1) contrast(1.1) brightness(0.9);"
									allowfullscreen=""
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade"
								/>
							) : mapImage ? (
								<img
									src={mapImage}
									alt="Service Area Map"
									class="absolute inset-0 w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
								/>
							) : (
								<div class="absolute inset-0 bg-muted flex items-center justify-center">
									<span class="text-muted-foreground font-black uppercase tracking-widest text-center px-4">
										Regional Perimeter Scan
									</span>
								</div>
							)}
						</div>

						{/* Floating Sharp Badge over map */}
						<div class="absolute top-4 right-4 md:top-8 md:right-8 z-20 bg-primary text-white p-4 md:p-6 shadow-2xl border-2 border-accent">
							<div class="flex flex-col gap-1">
								<span class="text-[10px] font-black uppercase tracking-[0.3em] opacity-80">
									Status
								</span>
								<span class="text-sm md:text-lg font-black uppercase tracking-tighter flex items-center gap-2">
									<span class="w-2 h-2 md:w-3 md:h-3 bg-accent animate-pulse" />
									Operational
								</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

<style>
	.grayscale-map:hover {
		filter: none !important;
	}
	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}
	.custom-scrollbar::-webkit-scrollbar-track {
		background: #f1f1f1;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: var(--brand-primary, #45f9ff);
	}
</style>
