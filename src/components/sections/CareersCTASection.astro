---
import { ArrowRight, Settings, Users } from "@lucide/astro";
import { getLocationText } from "@/config/site";

interface Props {
	title: string;
	description?: string;
	buttonText?: string;
	buttonHref?: string;
	image?: string;
	imageAlt?: string;
}

const {
	title: raw_title,
	description: raw_description,
	buttonText = "APPLY TODAY",
	buttonHref = "/contact",
	image,
	imageAlt = "Join our team",
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description
	? getLocationText(raw_description)
	: raw_description;
---

<section class="bg-primary relative overflow-hidden border-y-8 border-accent">
	{/* Technical Background */}
	<div
		class="absolute inset-0 opacity-10 pointer-events-none"
		style="background-image: repeating-linear-gradient(45deg, var(--brand-accent, #ff3d00) 0, var(--brand-accent, #ff3d00) 2px, transparent 0, transparent 50%); background-size: 30px 30px;">
	</div>

	<div class="container mx-auto px-4 relative z-10 py-24 md:py-32">
		<div class="grid lg:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">
			<div class="text-white" data-animate="fade-right">
				<h2
					class="text-4xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter leading-[0.9] mb-8 text-white">
					{title}
				</h2>

				{
					description && (
						<p
							class="text-lg font-medium leading-relaxed text-white/80 mb-12 max-w-lg"
							set:html={description}
						/>
					)
				}

				<div class="flex flex-wrap gap-6">
					<a
						href={buttonHref}
						class="group relative inline-flex items-center justify-center px-12 py-6 bg-accent text-primary font-black text-xs uppercase tracking-[0.3em] transition-all hover:bg-white rounded-none">
						<span class="relative z-10 flex items-center gap-3">
							{buttonText}
							<ArrowRight class="w-4 h-4 stroke-[4px]" />
						</span>
						<div
							class="absolute inset-0 bg-white translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform">
						</div>
					</a>

					<div
						class="flex items-center gap-4 px-6 border-l-4 border-accent/80">
						<Users class="w-6 h-6 text-accent" />
						<div class="flex flex-col">
							<span
								class="text-[10px] font-black uppercase tracking-widest text-accent/80"
								>Expansion</span
							>
							<span
								class="text-sm font-black uppercase tracking-tighter text-white"
								>Personnel_Acquisition</span
							>
						</div>
					</div>
				</div>
			</div>

			<div class="relative group" data-animate="fade-left">
				{/* Brutalist Frame */}
				<div
					class="absolute inset-0 bg-accent translate-x-6 translate-y-6">
				</div>
				<div
					class="relative bg-white border-4 border-white p-2 overflow-hidden shadow-2xl rounded-none">
					{
						image ? (
							<img
								src={image}
								alt={imageAlt}
								class="w-full h-auto object-cover grayscale group-hover:grayscale-0 transition-all duration-700 border-4 border-primary rounded-none"
							/>
						) : (
							<div class="aspect-[4/3] w-full bg-primary flex items-center justify-center">
								<Settings class="w-12 h-12 text-accent/20 animate-spin-slow" />
							</div>
						)
					}

					{/* Status Overlay */}
					<div
						class="absolute top-6 left-6 bg-primary text-white text-[10px] font-black px-4 py-1.5 uppercase tracking-[0.2em] border border-accent/30">
						OPERATIONAL_ASSET_02
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.animate-spin-slow {
		animation: spin 12s linear infinite;
	}
	@keyframes spin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}
</style>
