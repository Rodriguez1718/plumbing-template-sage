---
import {
	Phone,
	Mail,
	MapPin,
	Send,
	ShieldCheck,
	Clock,
	Settings,
} from "@lucide/astro";
import { getLocationText } from "@/config/site";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	phone?: string;
	email?: string;
	address?: string;
	serviceOptions?: string[];
	planOptions?: string[];
}

const {
	title: raw_title = "Get in Touch with {fullName}",
	description:
		raw_description = "Fill out the form, and a member of our team will get back to you promptly. Whether you're looking for a quick repair, a detailed quote, or general advice, we've got you covered.",
	image = "/images/photos/unsplash-1621905251189-08b45d6a269e-w800.jpg",
	phone: raw_phone = "{phone}",
	email: raw_email = "{email}",
	address: raw_address = "{city}, {state}",
	serviceOptions = [
		"Residential Plumbing",
		"Commercial Plumbing",
		"Emergency Service",
		"Maintenance",
		"Other",
	],
	planOptions = ["Yes", "No", "Not Sure"],
} = Astro.props;

// Process text placeholders
const title = getLocationText(raw_title);
const description = getLocationText(raw_description);
const phone = getLocationText(raw_phone);
const email = getLocationText(raw_email);
const address = getLocationText(raw_address);
---

{/* Header and Info Section */}
<section
	class="py-24 md:py-32 bg-white relative overflow-hidden border-b-4 border-primary">
	{/* Technical Background */}
	<div
		class="absolute inset-0 opacity-[0.03] pointer-events-none"
		style="background-image: radial-gradient(var(--brand-primary, #000) 2px, transparent 0); background-size: 30px 30px;">
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="max-w-6xl mx-auto">
			<div class="mb-16" data-animate="fade-up">
				<div class="flex items-center gap-3 mb-6">
					<div class="w-12 h-1 bg-accent"></div>
					<span
						class="text-[10px] font-black uppercase tracking-[0.4em] text-primary/40"
						>Communications_Hub_Mainframe</span
					>
				</div>
				<h2
					class="text-3xl sm:text-5xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-[1.1] mb-8">
					{title}
				</h2>
				<p
					class="text-lg font-medium tracking-tight leading-relaxed text-primary max-w-2xl"
					set:html={description}
				/>
			</div>

			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					[
						{
							label: "Direct_Link",
							value: phone,
							href: `tel:${phone}`,
							icon: Phone,
						},
						{
							label: "Data_Transmission",
							value: email,
							href: `mailto:${email}`,
							icon: Mail,
						},
						{
							label: "Operational_Base",
							value: address,
							icon: MapPin,
						},
					].map((item) => (
						<div class="group relative bg-white border-4 border-primary p-8 shadow-[8px_8px_0px_var(--accent)] hover:shadow-[12px_12px_0px_var(--accent)] transition-all duration-300">
							<div class="flex items-center gap-4 mb-4">
								<div class="w-10 h-10 bg-primary text-white flex items-center justify-center group-hover:bg-accent group-hover:text-primary transition-colors">
									<item.icon class="w-5 h-5 stroke-[3px]" />
								</div>
								<span class="text-[10px] font-black uppercase tracking-[0.2em] text-primary/40 group-hover:text-primary transition-colors">
									{item.label}
								</span>
							</div>
							{item.href ? (
								<a
									href={item.href}
									class="text-xl font-black text-primary uppercase tracking-tight hover:text-accent transition-colors block truncate">
									{item.value}
								</a>
							) : (
								<span class="text-xl font-black text-primary uppercase tracking-tight block truncate">
									{item.value}
								</span>
							)}
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

{/* Form Section with Image */}
<section
	class="py-24 md:py-32 bg-primary relative overflow-hidden border-b-4 border-accent">
	{/* Technical Pattern */}
	<div
		class="absolute inset-0 opacity-10 pointer-events-none"
		style="background-image: repeating-linear-gradient(45deg, var(--brand-accent, #ff3d00) 0, var(--brand-accent, #ff3d00) 2px, transparent 0, transparent 50%); background-size: 20px 20px;">
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center max-w-6xl mx-auto">
			<!-- Image Side -->
			<div class="relative order-2 lg:order-1" data-animate="fade-right">
				<div
					class="absolute inset-0 bg-accent translate-x-3 translate-y-3 sm:translate-x-6 sm:translate-y-6">
				</div>
				<div
					class="relative bg-white border-4 border-white p-2 shadow-2xl overflow-hidden">
					<img
						src={image}
						alt="Operational Personnel"
						class="w-full h-auto grayscale hover:grayscale-0 transition-all duration-700 border-4 border-primary"
					/>
					<div
						class="absolute bottom-4 left-4 bg-primary text-white text-[10px] font-black px-4 py-2 uppercase tracking-[0.2em]">
						SYSTEM_ID: VERIFIED_TECH
					</div>
				</div>
			</div>

			<!-- Form Side -->
			<div class="order-1 lg:order-2" data-animate="fade-left">
				<div
					class="bg-white border-4 border-primary p-6 sm:p-10 md:p-12 shadow-[16px_16px_0px_var(--accent)] relative">
					<div
						class="absolute top-0 right-10 bg-primary text-white text-[10px] font-black px-6 py-2 uppercase tracking-[0.3em]">
						FORM_SUBMISSION_MODULE
					</div>

					<div class="mb-10 pt-4">
						<h3
							class="text-2xl sm:text-3xl font-black text-primary uppercase tracking-tighter mb-2">
							INITIALIZE_REQUEST
						</h3>
						<p
							class="text-[10px] font-black text-primary/70 uppercase tracking-widest">
							Processing Time: &lt; 24.00_HRS
						</p>
					</div>

					<form class="space-y-6">
						<div class="grid md:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label
									for="name"
									class="text-[10px] font-black uppercase tracking-widest text-primary/80"
									>Personnel_Name</label
								>
								<input
									type="text"
									id="name"
									name="name"
									required
									class="w-full bg-white border-4 border-primary p-4 text-sm font-bold uppercase tracking-tight focus:bg-accent/5 focus:outline-none transition-colors placeholder:text-primary/20 rounded-none"
									placeholder="Enter_Full_Name"
								/>
							</div>
							<div class="space-y-2">
								<label
									for="phone"
									class="text-[10px] font-black uppercase tracking-widest text-primary/80"
									>Comm_Frequency</label
								>
								<input
									type="tel"
									id="phone"
									name="phone"
									class="w-full bg-white border-4 border-primary p-4 text-sm font-bold uppercase tracking-tight focus:bg-accent/5 focus:outline-none transition-colors placeholder:text-primary/20 rounded-none"
									placeholder="(000) 000-0000"
								/>
							</div>
						</div>

						<div class="space-y-2">
							<label
								for="email"
								class="text-[10px] font-black uppercase tracking-widest text-primary/80"
								>Digital_Address</label
							>
							<input
								type="email"
								id="email"
								name="email"
								required
								class="w-full bg-white border-4 border-primary p-4 text-sm font-bold uppercase tracking-tight focus:bg-accent/5 focus:outline-none transition-colors placeholder:text-primary/20 rounded-none"
								placeholder="USER@NETWORK.COM"
							/>
						</div>

						<div class="grid md:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label
									for="service"
									class="text-[10px] font-black uppercase tracking-widest text-primary/80"
									>Operations_Type</label
								>
								<div class="relative">
									<select
										id="service"
										name="service"
										class="w-full bg-white border-4 border-primary p-4 text-sm font-bold uppercase tracking-tight focus:bg-accent/5 focus:outline-none appearance-none cursor-pointer rounded-none">
										<option value="">SELECT_SERVICE</option>
										{
											serviceOptions.map((option) => (
												<option
													value={option
														.toLowerCase()
														.replace(/\s+/g, "-")}>
													{option.toUpperCase()}
												</option>
											))
										}
									</select>
									<Settings
										class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-primary/40 pointer-events-none"
									/>
								</div>
							</div>
							<div class="space-y-2">
								<label
									for="plan"
									class="text-[10px] font-black uppercase tracking-widest text-primary/80"
									>Module_Subscription</label
								>
								<div class="relative">
									<select
										id="plan"
										name="plan"
										class="w-full bg-white border-4 border-primary p-4 text-sm font-bold uppercase tracking-tight focus:bg-accent/5 focus:outline-none appearance-none cursor-pointer rounded-none">
										<option value="">TIER_INTEREST</option>
										{
											planOptions.map((option) => (
												<option
													value={option.toLowerCase()}>
													{option.toUpperCase()}
												</option>
											))
										}
									</select>
									<Settings
										class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-primary/40 pointer-events-none"
									/>
								</div>
							</div>
						</div>

						<div class="space-y-2">
							<label
								for="message"
								class="text-[10px] font-black uppercase tracking-widest text-primary/80"
								>Transmission_Data</label
							>
							<textarea
								id="message"
								name="message"
								rows="4"
								required
								class="w-full bg-white border-4 border-primary p-4 text-sm font-bold uppercase tracking-tight focus:bg-accent/5 focus:outline-none transition-colors resize-none placeholder:text-primary/20 rounded-none"
								placeholder="DESCRIBE_SITUATION_HERE..."
							></textarea>
						</div>

						<button
							type="submit"
							class="w-full bg-primary text-white py-5 px-6 sm:py-6 sm:px-10 font-black text-xs uppercase tracking-[0.4em] border-4 border-primary hover:bg-accent hover:text-primary transition-all active:translate-y-1 shadow-[8px_8px_0px_rgba(0,0,0,0.1)] flex items-center justify-center gap-4 rounded-none">
							INITIALIZE_UPLINK
							<Send class="w-4 h-4 stroke-[3px]" />
						</button>
					</form>

					{/* System Indicators */}
					<div
						class="mt-10 pt-6 border-t-4 border-primary/5 flex flex-wrap justify-between gap-4 text-[10px] font-black uppercase tracking-widest text-primary/70">>
						<span class="flex items-center gap-2">
							<ShieldCheck class="w-3 h-3 text-accent" />
							SECURE_LINK
						</span>
						<span class="flex items-center gap-2">
							<Clock class="w-3 h-3 text-accent" />
							PRIORITY_ROUTING
						</span>
						<span class="flex items-center gap-2 text-accent">
							<div class="w-2 h-2 bg-accent animate-pulse"></div>
							SYSTEM_ACTIVE
						</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
