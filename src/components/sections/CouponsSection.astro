---
import { Flame, Scissors, Clock } from '@lucide/astro';

interface Coupon {
  label: string;
  discount: string;
  description: string;
  expires: string;
}

interface Props {
  coupons: Coupon[];
}

const { coupons } = Astro.props;
---

<section class="py-16 md:py-24 bg-brand-tertiary/50 dark:bg-brand-primary/20">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <span class="inline-flex items-center gap-2 bg-accent text-accent-foreground text-sm font-bold px-4 py-1 rounded-full mb-4 animate-pulse">
        <Flame class="w-4 h-4" />
        LIMITED TIME OFFERS
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-primary">Save Big on Plumbing Services</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {coupons.map((coupon) => (
        <div class="coupon-card group relative bg-card border-2 border-dashed border-accent/40 rounded-lg p-6 text-center shadow-lg hover:shadow-xl hover:border-accent transition-all duration-300 overflow-hidden">
          <!-- Corner ribbon -->
          <div class="absolute -right-8 top-4 bg-accent text-accent-foreground text-xs font-bold py-1 px-10 rotate-45 shadow-md">
            SAVE
          </div>
          
          <!-- Scissors icon -->
          <div class="absolute -left-1 top-1/2 -translate-y-1/2 text-accent">
            <Scissors class="w-5 h-5" />
          </div>
          
          <span class="inline-block bg-accent/10 text-accent text-sm font-bold px-3 py-1 rounded-full uppercase tracking-wide">
            {coupon.label}
          </span>
          <h3 class="text-lg font-bold mt-3 mb-2 text-brand-secondary">Coupon</h3>
          <p class="text-sm text-muted-foreground mb-3">Redeem & Save Today</p>
          <div class="text-5xl md:text-6xl font-black text-accent mb-4 group-hover:scale-110 transition-transform duration-300">
            {coupon.discount}
          </div>
          <p class="text-sm text-muted-foreground mb-4">{coupon.description}</p>
          <div class="border-t border-dashed border-accent/30 pt-3 mt-3">
            <p class="inline-flex items-center gap-1 text-xs text-accent font-semibold">
              <Clock class="w-3 h-3" />
              Offer Expires: {coupon.expires}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .coupon-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), var(--brand-secondary), var(--accent));
  }
</style>
