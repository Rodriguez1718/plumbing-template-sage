---
import { Flame, Scissors, Settings } from "@lucide/astro";
import { getLocationText } from "@/config/site";

interface Coupon {
	label: string;
	discount: string;
	description: string;
	expires: string;
}

interface Props {
	coupons: Coupon[];
	variant?: "default" | "minimal";
}

const { coupons, variant = "default" } = Astro.props;
const isMinimal = variant === "minimal";
---

<section
	class="py-24 md:py-32 bg-white relative overflow-hidden border-b-4 border-primary">
	{/* Technical Background */}
	<div
		class="absolute inset-0 opacity-[0.04] pointer-events-none"
		style="background-image: linear-gradient(var(--brand-primary, #000) 1px, transparent 1px), linear-gradient(90deg, var(--brand-primary, #000) 1px, transparent 1px); background-size: 40px 40px;">
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="text-center mb-16 md:mb-24" data-animate="fade-up">
			<div class="flex items-center justify-center gap-4 mb-8">
				<div class="h-1 w-12 bg-accent"></div>
				<span
					class="inline-flex items-center gap-2 bg-primary text-white text-[10px] font-black px-4 py-1 uppercase tracking-[0.3em]">
					<Flame class="w-3 h-3 text-accent" />
					OFFER_DEPLOYMENT_ACTIVE
				</span>
				<div class="h-1 w-12 bg-accent"></div>
			</div>

			<h2
				class="text-4xl md:text-6xl font-black text-primary uppercase tracking-tighter leading-[0.9] mb-8">
				{
					isMinimal
						? "Strategic Discounts & Promotions"
						: "Infrastructure Maintenance Specials"
				}
			</h2>

			{
				isMinimal ? (
					<p
						class="text-lg font-medium leading-relaxed text-primary max-w-2xl mx-auto"
						set:html={`Current offers available for ${getLocationText("{fullName}")} customers. Select a module to initialize.`}
					/>
				) : (
					<p class="text-lg font-medium leading-relaxed text-primary max-w-2xl mx-auto">
						High-efficiency savings on core plumbing operations.
						Valid through system expiration dates.
					</p>
				)
			}
		</div>

		<div
			class={isMinimal
				? "grid sm:grid-cols-2 lg:grid-cols-3 gap-12 max-w-6xl mx-auto"
				: "grid md:grid-cols-3 gap-12 max-w-7xl mx-auto"}
			data-animate-stagger>
			{
				coupons.map((coupon) => (
					<div class="coupon-card group relative bg-white border-4 border-primary p-8 md:p-10 text-center shadow-[16px_16px_0px_rgba(0,0,0,0.05)] hover:shadow-[16px_16px_0px_var(--accent)] transition-all duration-500 overflow-visible">
						{/* Geometric Flag */}
						<div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white text-[10px] font-black py-1.5 px-6 uppercase tracking-[0.3em] shadow-lg border border-accent/20">
							{coupon.label}
						</div>

						<div class="space-y-6">
							<div class="space-y-1">
								<p class="text-[10px] font-black uppercase tracking-[0.4em] text-primary/70 flex items-center justify-center gap-2">
									<Settings class="w-3 h-3" />
									UNIT_VALUE
								</p>
								<div class="text-5xl md:text-7xl font-black text-primary tracking-tighter group-hover:scale-105 transition-transform duration-500">
									{coupon.discount}
								</div>
							</div>

							<p
								class="text-sm font-bold uppercase tracking-tight text-primary/70 leading-relaxed border-y-4 border-dashed border-primary/10 py-6"
								set:html={coupon.description}
							/>

							<div class="flex items-center justify-center gap-3 pt-2">
								<div class="w-2 h-2 bg-accent animate-pulse" />
								<p class="text-[10px] text-primary/70 font-black uppercase tracking-[0.2em]">
									EXPIRATION_CODE: {coupon.expires}
								</p>
							</div>
						</div>

						{/* Perforated Cut-outs */}
						<div class="absolute top-1/2 -left-4 w-8 h-8 bg-white border-4 border-primary rounded-full -translate-y-1/2 z-10 shadow-[inset_-2px_0px_4px_rgba(0,0,0,0.05)]" />
						<div class="absolute top-1/2 -right-4 w-8 h-8 bg-white border-4 border-primary rounded-full -translate-y-1/2 z-10 shadow-[inset_2px_0px_4px_rgba(0,0,0,0.05)]" />
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.coupon-card {
		background-image: linear-gradient(
			45deg,
			transparent 45%,
			rgba(var(--brand-primary-rgb, 69, 249, 255), 0.03) 50%,
			transparent 55%
		);
		background-size: 200% 200%;
		background-position: 100% 100%;
	}

	.coupon-card:hover {
		background-position: 0% 0%;
	}
</style>
