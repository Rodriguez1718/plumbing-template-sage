---
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
}

const { 
  badge: raw_badge, 
  title: raw_title, 
  description: raw_description, 
  features = [], 
  buttonText, 
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = []
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
---

<section class="py-20 md:py-32 bg-card relative overflow-hidden" style="border-bottom: 3px solid var(--brand-primary, #45f9ff);">
  <!-- Background Geometric Accent -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 -translate-y-1/2 translate-x-1/2 rotate-45 pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
      <!-- Image Section -->
      <div class={`${imagePosition === "right" ? "md:order-last" : ""} relative`} data-animate={imagePosition === "left" ? "fade-right" : "fade-left"}>
        {images.length > 0 ? (
          <div class="relative">
            <!-- Main Image with Brutalist Offset -->
            <div class="relative z-10 border-4 border-primary shadow-[16px_16px_0px_var(--accent)] overflow-hidden">
              <img 
                src={images[0].includes('ucarecdn.com') ? images[0].replace(/\/preview\/\d+x\d+/, '/preview/800x800').concat('-/format/webp/') : images[0]} 
                alt={imageAlts[0] || title} 
                class="w-full h-auto grayscale hover:grayscale-0 transition-all duration-700" 
                loading="lazy"
              />
            </div>
            
            <!-- Decorative Background Block -->
            <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-accent/20 -z-10 hidden md:block"></div>
            
            {images.length > 1 && (
              <!-- Secondary Overlapping Image -->
              <div class="absolute -bottom-10 -right-10 w-2/3 border-4 border-primary shadow-xl hidden md:block z-20 overflow-hidden bg-card">
                <img 
                  src={images[1].includes('ucarecdn.com') ? images[1].replace(/\/preview\/\d+x\d+/, '/preview/600x600').concat('-/format/webp/') : images[1]} 
                  alt={imageAlts[1] || `${title} - photo 2`} 
                  class="w-full h-auto" 
                  loading="lazy"
                />
              </div>
            )}
          </div>
        ) : (
          <div class="aspect-video bg-muted border-4 border-dashed border-primary/20 flex items-center justify-center">
            <span class="text-primary/20 font-black uppercase tracking-widest">Image Placeholder</span>
          </div>
        )}
      </div>

      <!-- Content Section -->
      <div class="space-y-8" data-animate="fade-up">
        <div class="space-y-4">
          {badge && (
            <span class="inline-block bg-accent text-accent-foreground text-[10px] font-black px-3 py-1 uppercase tracking-[0.2em]">
              {badge}
            </span>
          )}
          <h2 class="text-4xl md:text-5xl font-black text-foreground leading-[1.1] tracking-tighter uppercase">
            {title}
          </h2>
          <div class="w-16 h-1.5 bg-accent"></div>
        </div>

        <p class="text-lg text-muted-foreground leading-relaxed font-medium" set:html={description} />

        {features.length > 0 && (
          <ul class="grid sm:grid-cols-2 gap-4">
            {features.map((feature) => (
              <li class="flex items-start gap-3 group">
                <div class="mt-1 w-5 h-5 flex-shrink-0 flex items-center justify-center bg-primary text-white group-hover:bg-accent group-hover:text-accent-foreground transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-sm font-bold text-foreground/80 leading-tight">{feature}</span>
              </li>
            ))}
          </ul>
        )}

        {buttonText && buttonHref && (
          <div class="pt-4">
            <a 
              href={buttonHref} 
              class="group relative inline-flex items-center justify-center px-10 py-5 bg-primary text-primary-foreground font-black text-xs uppercase tracking-widest transition-all">
              <span class="relative z-10">{buttonText}</span>
              <div class="absolute inset-0 bg-accent translate-x-2 translate-y-2 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
