---
import { siteConfig } from "@/config/site"

interface Props {
  badge?: string
  title: string
  subtitle: string
  buttonText?: string
  buttonHref?: string
  image: string
}

const { 
  badge, 
  title, 
  subtitle, 
  buttonText = "Talk to Our Team", 
  buttonHref = "/contact", 
  image 
} = Astro.props

// Process location text
const processText = (text: string) => text
  .replaceAll("{city}", siteConfig.location.city)
  .replaceAll("{state}", siteConfig.location.state)
  .replaceAll("{business}", siteConfig.business.name)

const processedTitle = processText(title)
const processedSubtitle = processText(subtitle)
const processedBadge = badge ? processText(badge) : undefined
---

<div class="container mx-auto px-4 py-8 md:py-16">
  <section class="relative min-h-[50vh] md:min-h-[70vh] flex items-center rounded-xl md:rounded-2xl overflow-hidden shadow-2xl bg-brand-primary">
    <!-- Mobile: gradient background only, Desktop: image -->
    <div class="absolute inset-0 z-0">
      <img 
        src={image} 
        alt="Hero background showcasing our services" 
        class="hidden md:block w-full h-full object-cover"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
      <!-- Mobile gradient fallback -->
      <div class="md:hidden absolute inset-0 bg-gradient-to-br from-brand-primary via-brand-primary/90 to-brand-secondary/50"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/50 to-black/20"></div>
    </div>
    <div class="relative z-10 px-6 md:px-12 lg:px-16 py-8 md:py-12">
      <div class="max-w-2xl">
        {processedBadge && (
          <span class="inline-block px-3 py-1 md:px-4 md:py-1.5 mb-4 md:mb-6 text-xs md:text-sm font-medium text-white bg-brand-primary/30 rounded-full">
            {processedBadge}
          </span>
        )}
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4 md:mb-6">{processedTitle}</h1>
        <p class="text-base md:text-lg lg:text-xl text-white/80 mb-6 md:mb-8">{processedSubtitle}</p>
        <a 
          href={buttonHref}
          class="inline-flex items-center justify-center gap-2 h-11 md:h-12 rounded-lg md:rounded-xl px-6 md:px-8 py-2.5 md:py-3 bg-brand-primary hover:opacity-90 text-white text-sm font-medium transition-all"
        >
          {buttonText}
        </a>
      </div>
    </div>
  </section>
</div>
