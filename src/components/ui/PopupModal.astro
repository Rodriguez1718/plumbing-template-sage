---
import { siteConfig, getLocationText } from "@/config/site";

interface Props {
	delay?: number;
	showOnce?: boolean;
	triggerId?: string;
}

const {
	delay = 5000,
	showOnce = true,
	triggerId = "free-scan-trigger",
} = Astro.props;

const phoneRaw = siteConfig.contact.phone;
const phoneFormatted = siteConfig.contact.phoneFormatted;
---

<div
	id="popup-modal"
	class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
	role="dialog"
	aria-modal="true"
	aria-labelledby="popup-title"
	data-delay={delay}
	data-show-once={showOnce}
	data-trigger-id={triggerId}>
	<div
		class="relative w-full max-w-lg mx-4 bg-card border-4 border-primary shadow-[20px_20px_0px_rgba(0,0,0,0.1)] overflow-hidden animate-scale-in">
		
		<div class="flex flex-col md:flex-row h-full">
			<!-- Left: Image Section (Hidden on mobile or smaller) -->
			<div class="relative w-full md:w-5/12 h-48 md:h-auto overflow-hidden bg-primary">
				<img
					src="/images/photos/ucare-315825d3-1000x666.jpg"
					alt="Professional plumbing team"
					class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 opacity-60"
					loading="lazy"
					decoding="async"
				/>
				<div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
				
				<!-- Vertical Accent Line -->
				<div class="absolute top-0 right-0 w-1 h-full bg-accent/50 hidden md:block"></div>

				<!-- Discount Badge (Overlay on image) -->
				<div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center">
					<div class="text-6xl font-black text-white tracking-tighter drop-shadow-lg">
						$50
					</div>
					<div class="text-xl font-bold text-accent uppercase tracking-[0.2em]">
						OFF
					</div>
				</div>
			</div>

			<!-- Right: Content Section -->
			<div class="relative w-full md:w-7/12 p-8 md:p-10 flex flex-col justify-center">
				<!-- Close button (Geometric) -->
				<button
					id="close-popup"
					class="cursor-pointer absolute top-0 right-0 w-10 h-10 flex items-center justify-center bg-primary text-white hover:bg-accent hover:text-accent-foreground transition-colors duration-200"
					aria-label="Close popup">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>

				<div class="space-y-6">
					<div class="space-y-2">
						<div class="inline-block bg-accent text-accent-foreground text-[10px] font-black px-2 py-0.5 uppercase tracking-[0.2em]">
							Limited Time Invitation
						</div>
						<h2 id="popup-title" class="text-3xl font-black text-foreground leading-none tracking-tight uppercase">
							Priority <br/><span class="text-primary">Service</span>
						</h2>
						<p class="text-sm text-muted-foreground leading-relaxed font-medium">
							Licensed experts ready to solve your plumbing needs today. Save $50 on any service over $500.
						</p>
					</div>

					<!-- Sharp Divider -->
					<div class="w-12 h-1 bg-primary"></div>

					<!-- CTA buttons (Sharp) -->
					<div class="space-y-3">
						<a
							href="/contact"
							class="group relative block w-full px-6 py-4 bg-primary text-primary-foreground text-center font-black text-xs uppercase tracking-widest hover:bg-primary/90 transition-all">
							<span class="relative z-10">Claim Discount Now</span>
							<div class="absolute inset-0 bg-accent translate-x-1 translate-y-1 -z-10 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
						</a>
						
						<a
							href={`tel:${phoneRaw}`}
							class="flex items-center justify-center gap-3 w-full px-6 py-4 border-2 border-primary text-foreground text-center font-bold text-xs uppercase tracking-widest hover:bg-primary hover:text-white transition-all">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
							</svg>
							{phoneFormatted}
						</a>
					</div>

					<button
						id="close-popup-bottom"
						class="text-[10px] font-black text-muted-foreground uppercase tracking-widest hover:text-primary transition-colors text-center w-full">
						Dismiss Offer
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	function showPopup() {
		const popup = document.getElementById("popup-modal");
		if (!popup) return;
		popup.classList.remove("hidden");
		popup.classList.add("flex");
		document.body.style.overflow = "hidden";
		sessionStorage.setItem("popup-shown", "true");
	}

	function closePopup() {
		const popup = document.getElementById("popup-modal");
		if (!popup) return;
		popup.classList.add("hidden");
		popup.classList.remove("flex");
		document.body.style.overflow = "";
	}

	function initPopup() {
		const popup = document.getElementById("popup-modal");
		if (!popup) return;

		const alreadyShown = sessionStorage.getItem("popup-shown") === "true";
		const triggerId = popup.getAttribute("data-trigger-id");

		document
			.getElementById("close-popup")
			?.addEventListener("click", closePopup);
		document
			.getElementById("close-popup-bottom")
			?.addEventListener("click", closePopup);
		popup.addEventListener("click", (e) => {
			if (e.target === popup) closePopup();
		});
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !popup.classList.contains("hidden"))
				closePopup();
		});

		if (triggerId) {
			document
				.getElementById(triggerId)
				?.addEventListener("click", (e) => {
					e.preventDefault();
					showPopup();
				});
		}

		const delay = parseInt(popup.getAttribute("data-delay") || "0") || 0;
		if (delay > 0 && window.innerWidth >= 768 && !alreadyShown) {
			setTimeout(() => {
				if (window.innerWidth >= 768) showPopup();
			}, delay);
		}
	}

	document.addEventListener("astro:page-load", initPopup);
</script>

<style>
	@keyframes scale-in {
		from {
			opacity: 0;
			transform: scale(0.9);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}
	.animate-scale-in {
		animation: scale-in 0.3s ease-out;
	}
</style>
