---
// Floating Free Scan button that triggers the popup modal
// Only visible on desktop (md and up)
---

<button
  id="free-scan-trigger"
  class="hidden md:flex fixed bottom-8 right-8 z-40 items-center gap-2 h-12 px-6 py-3 bg-brand-secondary text-white font-medium text-sm rounded-xl shadow-lg hover:opacity-90 hover:scale-105 transition-all duration-300 group"
  aria-label="Ask for a Free Scan"
>
  <svg
    class="w-5 h-5 group-hover:scale-110 transition-transform duration-300"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
    ></path>
  </svg>
  <span>Ask for a Free Scan</span>
</button>

<style>
  /* Pulse animation for attention */
  @keyframes pulse-shadow {
    0%, 100% {
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05), 0 0 0 0 rgba(0, 145, 142, 0.4);
    }
    50% {
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05), 0 0 0 10px rgba(0, 145, 142, 0);
    }
  }

  #free-scan-trigger {
    animation: pulse-shadow 2s infinite;
  }

  #free-scan-trigger:hover {
    animation: none;
  }
</style>
